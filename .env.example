# Copy to .env and fill in real values.
# .env is gitignored - never commit real secrets.

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yoursite.example/api/auth/callback

# Discord user ID auto-promoted to admin on first login (Right-click name in
# Discord with Developer Mode on → Copy User ID).
AP_OWNER_DISCORD_ID=

# Flask session secret. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Postgres password for the bundled DB. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# Public hostname shown to players for AP server connections.
AP_HOST=localhost

# Comma-separated allowed CORS origins (no wildcards in production).
# Local dev: AP_CORS_ORIGINS=http://localhost:5173,http://localhost:5001
AP_CORS_ORIGINS=https://yoursite.example

# ── Feature flags ───────────────────────────────────────────────
# Each flag gates a coherent surface (UI + endpoints). Defaults are ON.
# Set to false to ship a scoped-down build.

# generation: AP server-side generation, server launch/stop, APWorld install.
# Set false to ship as a YAML collector only - hosts download YAMLs and
# run generation themselves off-server.
FEATURE_GENERATION=true
